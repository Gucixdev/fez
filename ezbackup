#!/usr/bin/env bash
. "$(dirname "${BASH_SOURCE[0]}")/_ez.sh"

SNAP_DIR="/snapshots"
DEV="/dev/sda2"
DATE=$(date +%Y%m%d-%H%M%S)

snap() {
    local target="${2:-root}"
    local label="${3:-manual}"
    case "$target" in
        root) sudo btrfs subvolume snapshot -r / "$SNAP_DIR/${label}-${DATE}" && echo "Snapshot root: ${label}-${DATE}" ;;
        home) sudo btrfs subvolume snapshot -r /home "$SNAP_DIR/${label}-home-${DATE}" && echo "Snapshot home: ${label}-home-${DATE}" ;;
        all)  snap _ root "$label"; snap _ home "$label" ;;
        *)    echo "Uzycie: ezbackup snap [root|home|all] [label]" ;;
    esac
}

pre() {
    sudo btrfs subvolume snapshot -r / "$SNAP_DIR/pre-update-${DATE}"
    echo "Pre-update snapshot: pre-update-${DATE}"
}

_snap_date() {
    local name=$(basename "$1")
    local ts=$(echo "$name" | grep -o '[0-9]\{8\}-[0-9]\{6\}' | head -1)
    [[ -n "$ts" ]] && echo "${ts:0:4}-${ts:4:2}-${ts:6:2} ${ts:9:2}:${ts:11:2}:${ts:13:2}" || stat -c '%y' "$1" 2>/dev/null | cut -d. -f1
}

_snaps() {
    local -n _arr="$1"
    _arr=()
    [[ ! -d "$SNAP_DIR" ]] && return
    for s in "$SNAP_DIR"/*/; do [[ -d "$s" ]] && _arr+=("$s"); done
    for s in "$SNAP_DIR"/*; do [[ -d "$s" && ! "$s" == */ ]] && _arr+=("$s"); done
    # deduplicate via glob expansion (just use simple glob)
    _arr=()
    for s in "$SNAP_DIR"/*; do [[ -e "$s" ]] && _arr+=("$s"); done
}

list() {
    local snaps; _snaps snaps
    [[ ${#snaps[@]} -eq 0 ]] && echo "Brak snapshotow w $SNAP_DIR" && return
    echo "Snapshoty w $SNAP_DIR:"
    local i=1
    for s in "${snaps[@]}"; do
        printf "%3d) %-40s  %s\n" "$i" "$(basename "$s")" "$(_snap_date "$s")"
        ((i++))
    done
    echo; echo "Lacznie: $((i-1))"
}

delete() {
    local snaps; _snaps snaps
    [[ ${#snaps[@]} -eq 0 ]] && echo "Brak snapshotow" && return

    local selected=()
    for s in "${snaps[@]}"; do selected+=(0); done

    while true; do
        echo "=== Wybierz do usuniecia ==="
        local i=1
        for s in "${snaps[@]}"; do
            local mark="[ ]"; [[ "${selected[$((i-1))]}" == 1 ]] && mark="[x]"
            printf "  %s %2d) %-40s  %s\n" "$mark" "$i" "$(basename "$s")" "$(_snap_date "$s")"
            ((i++))
        done
        local zaznaczone=$(printf '%s\n' "${selected[@]}" | grep -c '^1$')
        echo "(zaznaczono: $zaznaczone | nr=toggle, enter=potwierdz, q=anuluj)"
        echo -n "Nr: "; read -r inp

        case "$inp" in
            q|Q|exit) return ;;
            '') break ;;
            *[!0-9]*) echo "Wpisz numer" ;;
            *)
                local idx=$((inp-1))
                if [[ $idx -lt 0 || $idx -ge ${#snaps[@]} ]]; then
                    echo "Nieprawidlowy numer"
                elif [[ "${selected[$idx]}" == 1 ]]; then
                    selected[$idx]=0
                else
                    selected[$idx]=1
                fi
                ;;
        esac
    done

    local to_delete=()
    for i in "${!selected[@]}"; do
        [[ "${selected[$i]}" == 1 ]] && to_delete+=("${snaps[$i]}")
    done
    [[ ${#to_delete[@]} -eq 0 ]] && echo "Nic nie zaznaczono" && return

    echo "Do usuniecia:"
    printf '  - %s\n' "${to_delete[@]##*/}"
    echo -n "Potwierdzasz? [t/N] "; read -r yn
    [[ "$yn" != t && "$yn" != T ]] && echo "Anulowano" && return

    for s in "${to_delete[@]}"; do
        sudo btrfs subvolume delete "$s" && echo "Usunieto: $(basename "$s")"
    done
}

keep() {
    local n="${2:-5}"
    local snaps; _snaps snaps
    local count=${#snaps[@]}
    [[ $count -le $n ]] && echo "Masz $count snapshotow, limit=$n — nic do usuniecia" && return
    local to_delete=$(( count - n ))
    echo "Usuwam $to_delete najstarszych (zostaje $n):"
    for s in "${snaps[@]:0:$to_delete}"; do
        echo "  - $(basename "$s")"
        sudo btrfs subvolume delete "$s"
    done
}

restore() {
    list
    echo -n "Numer do przywrocenia: "; read -r n
    local snaps; _snaps snaps
    local snap_path="${snaps[$((n-1))]}"
    local name=$(basename "$snap_path")
    [[ -z "$name" || ! -d "$snap_path" ]] && echo "Nieprawidlowy numer" && return 1

    if [[ "$name" == *home* ]]; then
        echo -n "Przywrocic /home z '$name'? DANE BEDA NADPISANE [t/N] "; read -r yn
        [[ "$yn" != t && "$yn" != T ]] && return
        local back="$SNAP_DIR/home-before-restore-${DATE}"
        sudo btrfs subvolume snapshot -r /home "$back"
        echo "Backup biezacego /home -> $back"
        sudo rsync -aAX --delete "$snap_path/" /home/
        echo "Przywrocono /home z: $name"
    else
        echo
        echo "Snapshot root wymaga przywrocenia spoza dzialajacego systemu."
        echo "Instrukcja (z live USB lub TTY przed mountem):"
        echo
        echo "  mount $DEV /mnt"
        echo "  cd /mnt"
        echo "  mv @ @.old-${DATE}"
        echo "  btrfs subvolume snapshot @snapshots/$name @"
        echo "  umount /mnt"
        echo "  reboot"
        echo
        echo -n "Skopiowac komendy do schowka? [t/N] "; read -r yn
        if [[ "$yn" == t || "$yn" == T ]]; then
            printf "mount %s /mnt\ncd /mnt\nmv @ @.old-%s\nbtrfs subvolume snapshot @snapshots/%s @\numount /mnt\nreboot" \
                "$DEV" "$DATE" "$name" | wl-copy 2>/dev/null || \
            printf "mount %s /mnt\ncd /mnt\nmv @ @.old-%s\nbtrfs subvolume snapshot @snapshots/%s @\numount /mnt\nreboot" \
                "$DEV" "$DATE" "$name" | xclip -selection clipboard 2>/dev/null
            echo "Skopiowano"
        fi
    fi
}

export_snap() {
    local dest="${2}"
    [[ -z "$dest" ]] && { echo "Uzycie: ezbackup export <cel>  # np. /mnt/dysk lub user@host:/backup"; return 1; }
    list
    echo -n "Numer do exportu: "; read -r n
    local snaps=("$SNAP_DIR"/*)
    local snap_path="${snaps[$((n-1))]}"
    local name=$(basename "$snap_path")
    [[ -z "$name" ]] && echo "Nieprawidlowy numer" && return 1

    if [[ "$dest" == *:* ]]; then
        echo "Export przez rsync do $dest..."
        rsync -aAX --info=progress2 "$snap_path/" "$dest/$name/"
    else
        echo "Export przez btrfs send do $dest..."
        mkdir -p "$dest"
        sudo btrfs send "$snap_path" | sudo btrfs receive "$dest"
    fi
    echo "Export OK: $name → $dest"
}

status() {
    echo "Urzadzenie: $DEV"
    echo "Snapshoty:  $(ls "$SNAP_DIR" 2>/dev/null | wc -l)"
    btrfs filesystem df / 2>/dev/null | grep -E 'Data|Metadata'
}

all() { snap _ all manual; }

_do() {
    case "$1" in
        list)        list ;;
        snap)        snap _ "${2:-root}" ;;
        pre)         pre ;;
        delete)      delete ;;
        restore)     restore ;;
        keep)        keep _ "$2" ;;
        export_snap) export_snap _ "$2" ;;
        status)      status ;;
        all)         all ;;
        info)        info ;;
        *)           return 1 ;;
    esac
}

tui() {
    local cmds=(list snap pre delete restore keep export_snap status info)
    local descs=(
        "lista snapshotow"
        "nowy snapshot (root/home/all)"
        "snapshot przed updatem"
        "usun snapshot"
        "przywroc snapshot"
        "zachowaj ostatnie N"
        "exportuj na zewn. dysk/serwer"
        "status btrfs"
        "info + komendy"
    )
    while true; do
        echo "=== ezbackup | snapshots: $(ls "$SNAP_DIR" 2>/dev/null | wc -l) ==="
        for i in "${!cmds[@]}"; do printf "%2d) %-12s  %s\n" $((i+1)) "${cmds[$i]}" "${descs[$i]}"; done
        echo " 0) wyjdz  (lub: exit)"
        echo -n "Wybierz: "; read -r n
        _tui_dispatch "$n" cmds || break
        echo; echo -n "[Enter]"; read -r
    done
}

cli() {
    shift
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -l|--list)    list ;;
            -s|--snap)    shift; snap _ "${1:-root}" "${2:-manual}"; shift ;;
            -p|--pre)     pre ;;
            -d|--delete)  delete ;;
            -r|--restore) restore ;;
            -k|--keep)    shift; keep _ "$1" ;;
            -e|--export)  shift; export_snap _ "$1" ;;
            -S|--status)  status ;;
            *) echo "Nieznana flaga: $1"; echo "Flagi: -l -s [root|home|all] -p -d -r -k <n> -e <cel> -S" ;;
        esac
        shift
    done
}

info() {
    status
    echo
    echo "ezbackup list                  # lista snapshotow"
    echo "ezbackup snap [root|home|all]  # nowy snapshot"
    echo "ezbackup pre                   # snapshot przed updatem"
    echo "ezbackup delete                # usun (interaktywnie)"
    echo "ezbackup restore               # przywroc (interaktywnie)"
    echo "ezbackup keep <n>              # zachowaj ostatnie N"
    echo "ezbackup export <cel>          # exportuj na dysk/serwer"
    echo "ezbackup status                # stan btrfs"
    echo "ezbackup tui                   # interaktywne menu"
    echo "ezbackup cli [flagi]           # -l -s -p -d -r -k <n> -e <cel> -S"
}

case "${1:-info}" in
    tui)  tui ;;
    cli)  cli "$@" ;;
    snap) snap "$@" ;;
    keep) keep "$@" ;;
    export|export_snap) export_snap "$@" ;;
    *)    _do "${1:-info}" || echo "Uzycie: ezbackup [list|snap|pre|delete|restore|keep|export|status|all|tui|cli|info]" ;;
esac
