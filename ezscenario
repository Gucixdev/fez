#!/usr/bin/env bash
. "$(dirname "${BASH_SOURCE[0]}")/_ez.sh"

SCENARIO_DIR="$HOME/.local/share/ezscenario"

_check_deps() {
    local missing=()
    command -v evemu-record &>/dev/null || missing+=(evemu)
    command -v evemu-play   &>/dev/null || missing+=(evemu)
    [[ ${#missing[@]} -gt 0 ]] && echo "Brakuje: ${missing[*]}  →  sudo pacman -S evemu" && return 1
    return 0
}

_detect_keyboard() {
    grep 'Handlers=.*leds' /proc/bus/input/devices | grep -o 'event[0-9]*' | head -1 | sed 's/^/\/dev\/input\//'
}

_detect_mouse() {
    grep 'Handlers=.*mouse' /proc/bus/input/devices | grep -v 'kbd' | grep -o 'event[0-9]*' | head -1 | sed 's/^/\/dev\/input\//'
}

devices() {
    echo "Dostepne urzadzenia wejscia:"
    for ev in /dev/input/event*; do
        local name=$(cat "/sys/class/input/$(basename "$ev")/device/name" 2>/dev/null)
        printf "  %-20s  %s\n" "$(basename "$ev")" "$name"
    done
    echo
    echo "Auto-wykryto:"
    echo "  Klawiatura: $(_detect_keyboard)"
    echo "  Mysz:       $(_detect_mouse)"
}

_list_dirs() {
    local -n _out="$1"
    _out=()
    [[ ! -d "$SCENARIO_DIR" ]] && return
    for d in "$SCENARIO_DIR"/*/; do
        [[ -d "$d" ]] && _out+=("$d")
    done
}

list() {
    local dirs
    _list_dirs dirs
    [[ ${#dirs[@]} -eq 0 ]] && echo "Brak scenariuszy" && return
    local i=1
    for d in "${dirs[@]}"; do
        local name=$(basename "$d")
        local date=$(grep -o '"date": "[^"]*"' "$d/meta.json" 2>/dev/null | cut -d'"' -f4 | cut -dT -f1)
        local extras=""
        [[ -f "$d/screen.mkv" ]] && extras="+ekran"
        printf "%3d) %-35s  %-12s  %s\n" "$i" "$name" "$date" "$extras"
        ((i++))
    done
}

rec() {
    _check_deps || return 1
    local name="${2:-scenario-$(date +%Y%m%d-%H%M%S)}"

    local kb=$(_detect_keyboard)
    local ms=$(_detect_mouse)
    [[ -z "$kb" ]] && echo "Nie znaleziono klawiatury" && devices && return 1

    local dir="$SCENARIO_DIR/$name"
    mkdir -p "$dir"

    echo "Nagrywanie: $name"
    echo "  Klawiatura: $kb"
    [[ -n "$ms" ]] && echo "  Mysz:       $ms"

    echo -n "Nagrywac tez ekran? [t/N] "; read -r yn_screen

    local pids=()
    sudo evemu-record "$kb" > "$dir/keyboard.evemu" &
    pids+=($!)
    [[ -n "$ms" ]] && { sudo evemu-record "$ms" > "$dir/mouse.evemu" & pids+=($!); }
    if [[ "$yn_screen" == t || "$yn_screen" == T ]]; then
        wf-recorder -f "$dir/screen.mkv" &
        pids+=($!)
        echo "Nagrywanie ekranu aktywne"
    fi

    echo "{ \"name\": \"$name\", \"date\": \"$(date -Iseconds)\", \"kb\": \"$kb\", \"mouse\": \"$ms\" }" > "$dir/meta.json"
    printf '%s\n' "${pids[@]}" > "$SCENARIO_DIR/.rec_pids"
    echo "Nagrywanie... (Ctrl+C lub: ezscenario stop)"
    trap "kill ${pids[*]} 2>/dev/null" INT
    wait "${pids[@]}" 2>/dev/null
    trap - INT

    # trim ostatnich eventow Ctrl+C z nagrania (kod 29=LeftCtrl, 46=c)
    for f in "$dir/keyboard.evemu" "$dir/mouse.evemu"; do
        [[ -f "$f" ]] || continue
        # usun trailing SYN/KEY eventy klawiszy Ctrl i C z konca pliku
        local lines=$(wc -l < "$f")
        local trim=$(tac "$f" | awk '
            /^E [^ ]+ [^ ]+ 1 (29|46|4) / { next }
            /^E [^ ]+ [^ ]+ 0 (29|46|4) / { next }
            /^#/ { next }
            /^E [^ ]+ [^ ]+ 0 0$/ { next }
            { print NR; exit }
        ')
        [[ -n "$trim" && "$trim" -gt 1 ]] && head -n "-$((trim-1))" "$f" > "$f.tmp" && mv "$f.tmp" "$f"
    done

    echo "Zapisano: $dir"
}

run() {
    _check_deps || return 1
    local name
    if [[ -n "$2" ]]; then
        name="$2"
    else
        list
        echo -n "Numer: "; read -r n
        local dirs; _list_dirs dirs
        name=$(basename "${dirs[$((n-1))]}" 2>/dev/null)
        [[ -z "$name" ]] && echo "Nieprawidlowy numer" && return 1
    fi
    local dir="$SCENARIO_DIR/$name"
    [[ ! -d "$dir" ]] && echo "Brak scenariusza: $name" && return 1

    local kb=$(grep -o '"kb": "[^"]*"' "$dir/meta.json" 2>/dev/null | cut -d'"' -f4)
    local ms=$(grep -o '"mouse": "[^"]*"' "$dir/meta.json" 2>/dev/null | cut -d'"' -f4)
    [[ -z "$kb" ]] && kb=$(_detect_keyboard)

    echo "Odtwarzanie: $name  (Ctrl+C = stop)"
    local pids=()
    [[ -f "$dir/keyboard.evemu" ]] && { sudo evemu-play "$kb" < "$dir/keyboard.evemu" & pids+=($!); }
    [[ -f "$dir/mouse.evemu" && -n "$ms" ]] && { sudo evemu-play "$ms" < "$dir/mouse.evemu" & pids+=($!); }
    wait "${pids[@]}" 2>/dev/null
    echo "Odtwarzanie zakonczone"
    reset_keys
}

delete() {
    local dirs; _list_dirs dirs
    [[ ${#dirs[@]} -eq 0 ]] && echo "Brak scenariuszy" && return

    local selected=()
    for d in "${dirs[@]}"; do selected+=(0); done

    while true; do
        echo "=== Wybierz do usuniecia (spacja=toggle, enter=potwierdz, q=anuluj) ==="
        local i=1
        for d in "${dirs[@]}"; do
            local name=$(basename "$d")
            local mark="[ ]"
            [[ "${selected[$((i-1))]}" == 1 ]] && mark="[x]"
            printf "  %s %2d) %s\n" "$mark" "$i" "$name"
            ((i++))
        done
        local zaznaczone=$(printf '%s\n' "${selected[@]}" | grep -c '^1$')
        echo "(zaznaczono: $zaznaczone)"
        echo -n "Nr / enter / q: "; read -r inp

        case "$inp" in
            q|Q|exit) return ;;
            '') break ;;
            *[!0-9]*) echo "Wpisz numer" ;;
            *)
                local idx=$((inp-1))
                if [[ $idx -lt 0 || $idx -ge ${#dirs[@]} ]]; then
                    echo "Nieprawidlowy numer"
                elif [[ "${selected[$idx]}" == 1 ]]; then
                    selected[$idx]=0
                else
                    selected[$idx]=1
                fi
                ;;
        esac
    done

    local to_delete=()
    for i in "${!selected[@]}"; do
        [[ "${selected[$i]}" == 1 ]] && to_delete+=("$(basename "${dirs[$i]}")")
    done

    [[ ${#to_delete[@]} -eq 0 ]] && echo "Nic nie zaznaczono" && return

    echo "Do usuniecia:"
    printf '  - %s\n' "${to_delete[@]}"
    echo -n "Potwierdzasz? [t/N] "; read -r yn
    [[ "$yn" != t && "$yn" != T ]] && echo "Anulowano" && return

    for name in "${to_delete[@]}"; do
        rm -rf "$SCENARIO_DIR/$name"
        echo "Usunieto: $name"
    done
}

play_screen() {
    local name
    if [[ -n "$2" ]]; then
        name="$2"
    else
        list
        echo -n "Numer: "; read -r n
        local dirs; _list_dirs dirs
        name=$(basename "${dirs[$((n-1))]}" 2>/dev/null)
    fi
    local f="$SCENARIO_DIR/$name/screen.mkv"
    [[ ! -f "$f" ]] && echo "Brak nagrania ekranu dla: $name" && return 1
    mpv "$f" 2>/dev/null || vlc "$f" 2>/dev/null || xdg-open "$f"
}

stop() {
    local pidfile="$SCENARIO_DIR/.rec_pids"
    [[ ! -f "$pidfile" ]] && echo "Brak aktywnego nagrywania" && return 1
    while read -r pid; do
        kill "$pid" 2>/dev/null && echo "Zatrzymano PID $pid"
    done < "$pidfile"
    rm -f "$pidfile"
    echo "Nagrywanie zatrzymane"
}

reset_keys() {
    local kb=$(_detect_keyboard)
    [[ -z "$kb" ]] && echo "Nie znaleziono klawiatury" && return 1
    # EV_KEY=1, value=0 (release): oba Ctrl, oba Shift, oba Alt, oba Super, CapsLock, Tab
    local codes=(29 97 42 54 56 100 125 126 58 15)
    echo "Zwalnianie stuck keys na $kb..."
    for code in "${codes[@]}"; do
        sudo evemu-event "$kb" --sync --type 1 --code "$code" --value 0 2>/dev/null
    done
    echo "Klawisze zwolnione"
}

all() { rec; }

_do() {
    case "$1" in
        rec)        rec ;;
        run)        run ;;
        stop)       stop ;;
        reset_keys) reset_keys ;;
        list)       list ;;
        delete)     delete ;;
        play_screen) play_screen ;;
        devices)    devices ;;
        info)       info ;;
        *)          return 1 ;;
    esac
}

tui() {
    local cmds=(rec stop run list delete play_screen devices info)
    local descs=(
        "nagraj klawiature/mysz/ekran"
        "zatrzymaj nagrywanie (bez Ctrl+C)"
        "odtworz scenariusz"
        "lista scenariuszy"
        "usun (multi-select)"
        "odtworz nagranie ekranu"
        "pokaz urzadzenia wejscia"
        "info + komendy"
    )
    while true; do
        echo "=== ezscenario | scenariusze: $(ls "$SCENARIO_DIR" 2>/dev/null | wc -l) ==="
        for i in "${!cmds[@]}"; do printf "%2d) %-14s  %s\n" $((i+1)) "${cmds[$i]}" "${descs[$i]}"; done
        echo " 0) wyjdz  (lub: exit)"
        echo -n "Wybierz: "; read -r n
        _tui_dispatch "$n" cmds || break
        echo; echo -n "[Enter]"; read -r
    done
}

cli() {
    shift
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -r|--rec)     shift; rec _ "$1" ;;
            -R|--run)     shift; run _ "$1" ;;
            -l|--list)    list ;;
            -d|--delete)  delete ;;
            -p|--play)    shift; play_screen _ "$1" ;;
            -D|--devices) devices ;;
            *) echo "Nieznana flaga: $1"; echo "Flagi: -r [nazwa] -R [nazwa] -l -d -p [nazwa] -D" ;;
        esac
        shift
    done
}

info() {
    echo "Scenariusze: $SCENARIO_DIR"
    echo "Zapisane:    $(ls "$SCENARIO_DIR" 2>/dev/null | wc -l)"
    echo
    echo "ezscenario rec [nazwa]     # nagraj klawiature + mysz (+ ekran opcjonalnie)"
    echo "ezscenario run [nazwa]     # odtworz scenariusz"
    echo "ezscenario list            # lista scenariuszy"
    echo "ezscenario delete          # usun (multi-select)"
    echo "ezscenario play_screen     # odtworz nagranie ekranu"
    echo "ezscenario devices         # pokaz wykryte urzadzenia"
    echo "ezscenario tui             # interaktywne menu"
    echo "ezscenario cli [flagi]     # -r -R -l -d -p -D"
    echo
    command -v evemu-record &>/dev/null || echo "UWAGA: brakuje evemu  →  sudo pacman -S evemu"
}

case "${1:-info}" in
    tui) tui ;;
    cli) cli "$@" ;;
    rec) rec "$@" ;;
    run) run "$@" ;;
    play_screen) play_screen "$@" ;;
    *)   _do "${1:-info}" || echo "Uzycie: ezscenario [rec|run|stop|list|delete|play_screen|devices|all|tui|cli|info]" ;;
esac
