#!/usr/bin/env bash

# --- SETUP ---
SEP="------------------------------------------"
trap 'stty echo; echo -e "\nEXIT"; exit' SIGINT

# --- ENGINE ---
if command -v nmcli >/dev/null 2>&1; then
    MODE="nmcli"
elif command -v iwctl >/dev/null 2>&1; then
    MODE="iwd"
else
    MODE="iwlist"
fi

IFACE=$(ip link | grep -oE 'w(lan|lp|lo)[0-9][a-z0-9]*' | head -n 1)

# --- SCAN ---
clear
echo "$SEP"
echo "  MODE: $MODE | IFACE: $IFACE"
echo "$SEP"

case $MODE in
    "nmcli")
        nmcli dev wifi rescan 2>/dev/null
        mapfile -t NETS < <(nmcli -f "SSID" dev wifi | tail -n +2 | grep -v -- '--' | awk 'NF' | awk '!seen[$0]++')
        ;;
    "iwd")
        iwctl station "$IFACE" scan
        mapfile -t NETS < <(iwctl station "$IFACE" get-networks | tail -n +5 | sed -r "s/\x1B\[([0-9]{1,3}(;[0-9]{1,2})?)?[mGK]//g" | awk '{print $1}')
        ;;
    *)
        mapfile -t NETS < <(sudo iwlist "$IFACE" scanning | grep 'ESSID' | cut -d'"' -f2 | grep -v '^$')
        ;;
esac

# --- UI ---
for i in "${!NETS[@]}"; do
    printf "%-3s | %s\n" "$((i+1))" "${NETS[$i]}"
done

echo "$SEP"
read -n 1 -p "> " CH_RAW
echo -e "\n"

IDX=$((CH_RAW-1))
SSID=$(echo "${NETS[$IDX]}" | xargs)

if [[ -z "$SSID" || $((CH_RAW)) -lt 1 ]]; then
    echo "❌"; exit 1
fi

# --- AUTH ---
read -s -p "PASS ($SSID): " PASS
echo -e "\n$SEP"

# --- EXEC ---
case $MODE in
    "nmcli")
        nmcli dev wifi connect "$SSID" password "$PASS" >/dev/null 2>&1
        ;;
    "iwd")
        printf "%s\n" "$PASS" | iwctl station "$IFACE" connect "$SSID" >/dev/null 2>&1
        ;;
    *)
        CONF="/tmp/ez.conf"
        wpa_passphrase "$SSID" "$PASS" > "$CONF"
        sudo wpa_supplicant -B -i "$IFACE" -c "$CONF" >/dev/null 2>&1
        sudo dhclient "$IFACE" >/dev/null 2>&1
        ;;
esac

# --- DONE ---
sleep 2
ping -c 1 8.8.8.8 >/dev/null 2>&1 && echo "✅" || echo "❌"
echo "$SEP"
